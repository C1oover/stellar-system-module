<form class="solar-system-editor__form flexcol">
  <section class="solar-system-editor__hero">
    <div>
      <h2>{{sceneName}}</h2>
      <p>Scene-backed animated system. Autopopulate a baseline layout, then fine-tune individual bodies by clicking them on the canvas or in the list.</p>
    </div>
    <div class="solar-system-editor__hero-actions">
      <button type="button" data-action="autopopulate-single">Autopopulate Single Star</button>
      <button type="button" data-action="autopopulate-binary">Autopopulate Binary Stars</button>
    </div>
  </section>

  <section class="solar-system-editor__grid">
    <div class="solar-system-editor__panel">
      <h3>System</h3>
      <label class="solar-system-editor__checkbox">
        <input type="checkbox" name="system.enabled" data-action="enable-system" {{#if system.enabled}}checked{{/if}}>
        <span>Enable on this scene</span>
      </label>
      <label>
        <span>Animation Speed</span>
        <input type="number" step="0.1" name="system.animationSpeed" value="{{system.animationSpeed}}">
      </label>
      <label>
        <span>Background</span>
        <input type="color" name="system.backgroundColor" value="{{system.backgroundColor}}">
      </label>
      <label>
        <span>Starfield Density</span>
        <input type="number" step="1" name="system.starfieldDensity" value="{{system.starfieldDensity}}">
      </label>
      <label class="solar-system-editor__checkbox">
        <input type="checkbox" name="system.showLabels" {{#if system.showLabels}}checked{{/if}}>
        <span>Show labels</span>
      </label>
      <label class="solar-system-editor__checkbox">
        <input type="checkbox" name="system.showOrbits" {{#if system.showOrbits}}checked{{/if}}>
        <span>Show orbit lines</span>
      </label>
    </div>

    <div class="solar-system-editor__panel solar-system-editor__panel--bodies">
      <div class="solar-system-editor__panel-header">
        <h3>Bodies</h3>
        <div class="solar-system-editor__tiny-actions">
          <button type="button" data-action="add-star">+ Star</button>
          <button type="button" data-action="add-planet">+ Planet</button>
          <button type="button" data-action="add-moon">+ Moon</button>
        </div>
      </div>
      <div class="solar-system-editor__body-list">
        {{#each bodyList}}
          <button type="button" data-action="select-body" data-body-id="{{id}}" class="solar-system-editor__body-btn {{#if selected}}is-selected{{/if}}">
            {{name}}
          </button>
        {{/each}}
      </div>
    </div>
  </section>

  <section class="solar-system-editor__panel solar-system-editor__panel--details">
    <div class="solar-system-editor__panel-header">
      <h3>Selected Body</h3>
      <button type="button" data-action="delete-body" {{#unless hasSelectedBody}}disabled{{/unless}}>Delete</button>
    </div>

    {{#if hasSelectedBody}}
      <div class="solar-system-editor__detail-grid">
        <label>
          <span>Name</span>
          <input type="text" name="body.name" value="{{selectedBody.name}}">
        </label>
        <label>
          <span>Type</span>
          <select name="body.type">
            {{#each bodyTypeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          <span>Color</span>
          <input type="color" name="body.color" value="{{selectedBody.color}}">
        </label>
        <label>
          <span>Radius</span>
          <input type="number" step="1" name="body.radius" value="{{selectedBody.radius}}">
        </label>
        <label>
          <span>Glow</span>
          <input type="number" step="0.1" name="body.glow" value="{{selectedBody.glow}}">
        </label>
        <label class="solar-system-editor__checkbox">
          <input type="checkbox" name="body.showLabel" {{#if selectedBody.showLabel}}checked{{/if}}>
          <span>Show label</span>
        </label>
      </div>

      <div class="solar-system-editor__detail-grid">
        <label class="solar-system-editor__wide">
          <span>Description</span>
          <textarea name="body.description" rows="3">{{selectedBody.description}}</textarea>
        </label>
        <label class="solar-system-editor__wide">
          <span>Journal UUID</span>
          <input type="text" name="body.journalUuid" value="{{selectedBody.journalUuid}}" placeholder="Optional; for later journal integration">
        </label>
      </div>

      {{#if selectedIsStar}}
        <div class="solar-system-editor__subsection">
          <h4>Star / Binary Settings</h4>
          <div class="solar-system-editor__detail-grid">
            <label>
              <span>Binary Group</span>
              <input type="text" name="body.binaryGroup" value="{{selectedBody.binaryGroup}}" placeholder="Leave empty for single star">
            </label>
            <label>
              <span>Binary Separation</span>
              <input type="number" step="1" name="body.binarySeparation" value="{{selectedBody.binarySeparation}}">
            </label>
            <label>
              <span>Binary Period</span>
              <input type="number" step="0.1" name="body.binaryPeriod" value="{{selectedBody.binaryPeriod}}">
            </label>
            <label>
              <span>Binary Phase</span>
              <input type="number" step="0.1" name="body.binaryPhase" value="{{selectedBody.binaryPhase}}">
            </label>
          </div>
        </div>
      {{/if}}

      {{#if selectedIsNotStar}}
        <div class="solar-system-editor__subsection">
          <h4>Orbit Settings</h4>
          <div class="solar-system-editor__detail-grid">
            <label>
              <span>Parent</span>
              <select name="body.parentId">
                {{#each parentOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label>
              <span>Orbit Target</span>
              <select name="body.orbitTarget">
                {{#each targetOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label>
              <span>Mode</span>
              <select name="body.orbitMode">
                {{#each orbitModeOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <label>
              <span>Orbit Radius X</span>
              <input type="number" step="1" name="body.orbitRadiusX" value="{{selectedBody.orbitRadiusX}}">
            </label>
            <label>
              <span>Orbit Radius Y</span>
              <input type="number" step="1" name="body.orbitRadiusY" value="{{selectedBody.orbitRadiusY}}">
            </label>
            <label>
              <span>Orbit Period</span>
              <input type="number" step="0.1" name="body.orbitPeriod" value="{{selectedBody.orbitPeriod}}">
            </label>
            <label>
              <span>Orbit Phase</span>
              <input type="number" step="0.1" name="body.orbitPhase" value="{{selectedBody.orbitPhase}}">
            </label>
          </div>
        </div>

        <div class="solar-system-editor__subsection">
          <h4>Dual Planet / Companion Pair</h4>
          <div class="solar-system-editor__detail-grid">
            <label>
              <span>Pair ID</span>
              <input type="text" name="body.pairId" value="{{selectedBody.pairId}}" placeholder="Shared ID with partner body">
            </label>
            <label>
              <span>Pair Distance</span>
              <input type="number" step="1" name="body.pairDistance" value="{{selectedBody.pairDistance}}">
            </label>
            <label>
              <span>Pair Period</span>
              <input type="number" step="0.1" name="body.pairPeriod" value="{{selectedBody.pairPeriod}}">
            </label>
            <label>
              <span>Pair Phase</span>
              <input type="number" step="0.1" name="body.pairPhase" value="{{selectedBody.pairPhase}}">
            </label>
          </div>
        </div>
      {{/if}}
    {{else}}
      <p>Create a body or choose one from the list.</p>
    {{/if}}
  </section>
</form>
